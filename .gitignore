build
.vscode
build.log
src/version_gen.rc
src/source_link_gen.json

# outputs
out
*.nupkg

# Claude Code - ignore local settings, keep hooks and shared settings
/.claude/*
!/.claude/hooks/
!/.claude/settings.json

# fork-sync work folders
.sync/
.logs/
node_modules/

# fork-sync generated per-dependency PR notes (regenerated on each sync)
sync-pr-notes.md

# The vendored Chromium subset (deps/chromium) ships directories named `build`
# that the broad, unanchored `build` ignore above would otherwise hide. Re-include
# them so the whole vendored tree is tracked. (Our own GN output lives in
# deps/chromium/out and stays ignored via the `out` rule.)
!/deps/chromium/**/build/

# tests/ (real-consumer e2e/integration tests) — build outputs + NuGet restore.
# Source files (main.cpp, consumer.vcxproj, *.ps1 drivers, packages.config)
# stay tracked.
tests/bin/
tests/obj/
tests/packages/
tests/snap/

# gyp-generated stub .sln files under src/ — gyp emits a per-gyp-file .sln
# alongside the .vcxproj files, but the only solution we actually build
# against is deps/nodejs/node.sln (which aggregates everything). These
# stubs have no Project() entries and aren't referenced by anything.
src/**/*.sln

# Generated VERSIONINFO numbers header for the Microsoft.JavaScript.V8 package
# binaries (produced from config.json by src/generate_version_info.ts; consumed
# by src/version_info.rc). Regenerated by both the gyp and gn builds.
src/version_info_gen.h
